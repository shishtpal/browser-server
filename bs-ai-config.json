{
  "default_provider": "openrouter",
  "providers": {
    "openrouter": {
      "type": "openai_compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key": "env:OPENROUTER_API_KEY",
      "request_timeout_seconds": 120,
      "models": [
        {
          "id": "openai/gpt-4o-mini",
          "label": "GPT-4o Mini",
          "supports_tools": true,
          "default": true,
          "max_output_tokens": 4096
        },
        {
          "id": "anthropic/claude-sonnet-4",
          "label": "Claude Sonnet 4",
          "supports_tools": true,
          "max_output_tokens": 8192
        }
      ]
    }
  },
  "tools": {
    "enabled": true,
    "allowed": [
      "get_current_time",
      "search_bookmarks",
      "execute_command",
      "read_file",
      "write_file",
      "list_directory",
      "delete_file",
      "move_file",
      "copy_file"
    ],
    "max_iterations": 5
  },
  "logging": {
    "enabled": true,
    "db_path": ".data/bs-ai.db",
    "retention_days": 60,
    "log_full_payload": true,
    "max_payload_bytes": 1048576
  },
  "chat": {
    "system_prompt": "You are a helpful assistant integrated into browser-server.",
    "max_history_messages": 30,
    "stream": true,
    "temperature": 0.7
  }
}
