<div class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
  <section class="overflow-hidden rounded-[2rem] border border-gray-200/80 bg-white/90 p-6 shadow-2xl shadow-gray-900/10 backdrop-blur-xl transition-colors dark:border-white/10 dark:bg-slate-800/90 dark:shadow-slate-950/20 sm:p-10">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="mb-3 inline-flex rounded-full bg-teal-50 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-teal-700 transition-colors dark:bg-teal-900/20 dark:text-teal-400">Contact</p>
        <h1 class="text-4xl font-black tracking-tight text-slate-900 transition-colors dark:text-white sm:text-5xl">Send us a message</h1>
        <p class="mt-4 text-base leading-7 text-slate-600 transition-colors dark:text-slate-400">Have feedback, ideas, or questions? We would love to hear from you.</p>
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <div class="rounded-3xl bg-slate-900 p-4 text-white transition-colors dark:bg-slate-950">
            <div class="text-2xl font-black">24h</div>
            <div class="text-xs font-bold text-slate-300">Typical reply</div>
          </div>
          <div class="rounded-3xl bg-teal-500 p-4 text-white">
            <div class="text-2xl font-black">1:1</div>
            <div class="text-xs font-bold text-teal-50">Personal support</div>
          </div>
          <div class="rounded-3xl bg-indigo-500 p-4 text-white">
            <div class="text-2xl font-black">UI</div>
            <div class="text-xs font-bold text-indigo-50">Feedback welcome</div>
          </div>
        </div>
      </div>

      <form id="contact-form" class="rounded-[1.75rem] border border-gray-200 bg-white p-5 shadow-xl shadow-gray-900/10 transition-colors dark:border-slate-700 dark:bg-slate-800/90 dark:shadow-slate-950/20 sm:p-6" method="POST">
        <div class="grid gap-4">
          <div>
            <label class="mb-2 block text-sm font-black text-slate-700 transition-colors dark:text-slate-300" for="contact-name">Your name</label>
            <input
              id="contact-name"
              class="w-full rounded-2xl border border-gray-300 bg-gray-50 px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm transition placeholder:text-slate-400 focus:border-teal-400 focus:bg-white focus:outline-none focus:ring-4 focus:ring-teal-100 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:placeholder:text-slate-500 dark:focus:ring-teal-900/30"
              type="text"
              placeholder="Jane Doe"
              name="name"
              required
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-black text-slate-700 transition-colors dark:text-slate-300" for="contact-email">Your email</label>
            <input
              id="contact-email"
              class="w-full rounded-2xl border border-gray-300 bg-gray-50 px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm transition placeholder:text-slate-400 focus:border-teal-400 focus:bg-white focus:outline-none focus:ring-4 focus:ring-teal-100 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:placeholder:text-slate-500 dark:focus:ring-teal-900/30"
              type="email"
              placeholder="jane@example.com"
              name="email"
              required
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-black text-slate-700 transition-colors dark:text-slate-300" for="contact-message">Message</label>
            <textarea
              id="contact-message"
              class="min-h-36 w-full resize-y rounded-2xl border border-gray-300 bg-gray-50 px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm transition placeholder:text-slate-400 focus:border-teal-400 focus:bg-white focus:outline-none focus:ring-4 focus:ring-teal-100 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:placeholder:text-slate-500 dark:focus:ring-teal-900/30"
              placeholder="Tell us what you think..."
              name="message"
              required
            ></textarea>
          </div>
          <button
            class="rounded-2xl bg-gradient-to-r from-teal-500 to-emerald-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-teal-500/25 transition hover:-translate-y-0.5 hover:shadow-xl hover:shadow-teal-500/30 focus:outline-none focus:ring-4 focus:ring-teal-200 dark:focus:ring-teal-900/40"
            type="submit"
          >
            Send message
          </button>
        </div>
      </form>
    </div>
  </section>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form')

    form.addEventListener('submit', async (event) => {
      event.preventDefault()

      const formData = new FormData(form)
      const response = await fetch('https://formsubmit.co/ajax/demo@gmail.com', {
        method: 'POST',
        body: formData
      })

      if (response.ok) {
        alert('Form submitted successfully!')
        form.reset()
      } else {
        alert('Form submission failed!')
      }
    })
  })
</script>
