---
import '../styles/global.css'
import ThemeToggle from '../components/ThemeToggle.vue'

interface Props {
  title?: string
}
const { title } = Astro.props
const pageTitle = title ? `${title} | Browser Server` : 'Browser Server'
const activePath = Astro.url.pathname
const navItems = [
  { href: '/', label: 'Todos' },
  { href: '/bookmarks/', label: 'Bookmarks' },
  { href: '/history/', label: 'History' },
  { href: '/wallet/', label: 'Wallet' },
  { href: '/users/', label: 'Users' },
  { href: '/about/', label: 'About' },
]
const isActive = (href: string) => {
  if (href === '/') return activePath === '/'
  const p = activePath.endsWith('/') ? activePath : activePath + '/'
  return p.startsWith(href)
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <script is:inline>
      (function () {
        const theme = localStorage.getItem('theme') || 'system'
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        if (theme === 'dark' || (theme === 'system' && systemDark)) {
          document.documentElement.classList.add('dark')
        } else {
          document.documentElement.classList.remove('dark')
        }
      })()
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 text-slate-900 transition-colors duration-300 dark:bg-slate-950 dark:text-white">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute left-1/2 top-0 h-96 w-96 -translate-x-1/2 rounded-full bg-indigo-500/10 blur-3xl dark:bg-indigo-500/25"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-cyan-400/10 blur-3xl dark:bg-cyan-400/20"></div>
      <div class="absolute right-0 top-1/3 h-80 w-80 rounded-full bg-violet-500/10 blur-3xl dark:bg-violet-500/20"></div>
    </div>

    <header class="sticky top-0 z-50 border-b border-gray-200/80 bg-white/80 backdrop-blur-xl transition-colors dark:border-white/10 dark:bg-slate-950/80">
      <nav class="mx-auto flex w-full max-w-full items-center justify-between px-4 py-2 sm:px-6 lg:px-10 xl:px-12" aria-label="Main navigation">
        <a href="/" class="group flex items-center gap-2">
          <span class="grid h-8 w-8 place-items-center rounded-xl bg-gradient-to-br from-indigo-400 via-violet-400 to-cyan-300 text-sm font-black text-white shadow-lg shadow-indigo-500/25 transition group-hover:scale-105">B</span>
          <span class="hidden sm:block">
            <span class="block text-xs font-semibold tracking-wide text-slate-900 transition-colors dark:text-white">Browser Server</span>
            <span class="block text-[10px] text-slate-500 transition-colors dark:text-slate-400">Personal data hub</span>
          </span>
        </a>

        <div class="hidden items-center gap-0.5 md:flex">
          {
            navItems.map(item => (
              <a
                href={item.href}
                class={[
                  'rounded-lg px-3 py-1.5 text-xs font-semibold transition',
                  isActive(item.href)
                    ? 'bg-indigo-50 text-indigo-700 ring-1 ring-indigo-200 dark:bg-white/10 dark:text-white dark:ring-white/10 dark:shadow-white/5'
                    : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-white/80 dark:hover:bg-white/10 dark:hover:text-white'
                ]}
              >{item.label}</a>
            ))
          }
          <div class="ml-1">
            <ThemeToggle client:load />
          </div>
        </div>

        <div class="flex items-center gap-2 md:hidden">
          <ThemeToggle client:load />
          <button id="mobile-menu-btn" class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-gray-200 bg-gray-50 text-slate-600 transition hover:bg-gray-100 dark:border-white/10 dark:bg-white/5 dark:text-slate-200 dark:hover:bg-white/10" type="button" aria-label="Toggle menu" aria-expanded="false">
            <svg id="menu-icon-open" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="menu-icon-close" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </nav>

      <div id="mobile-menu" class="hidden border-t border-gray-200/80 bg-white/95 px-4 py-3 shadow-2xl dark:border-white/10 dark:bg-slate-950/95 md:hidden">
        <div class="mx-auto grid max-w-7xl gap-2">
          {
            navItems.map(item => (
              <a
                href={item.href}
                class={[
                  'rounded-2xl px-4 py-3 text-sm font-semibold transition',
                  isActive(item.href)
                    ? 'bg-gradient-to-r from-indigo-500/15 to-cyan-400/10 text-slate-900 ring-1 ring-slate-900/10 dark:from-indigo-500/25 dark:to-cyan-400/20 dark:text-white dark:ring-white/10'
                    : 'text-slate-700 hover:bg-gray-100 dark:text-white/90 dark:hover:bg-white/10 dark:hover:text-white'
                ]}
              >{item.label}</a>
            ))
          }
        </div>
      </div>
    </header>

    <slot />
  </body>
</html>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('menu-icon-open')
  const iconClose = document.getElementById('menu-icon-close')

  if (btn && menu && iconOpen && iconClose) {
    const closeMenu = () => {
      menu.classList.add('hidden')
      iconOpen.classList.remove('hidden')
      iconClose.classList.add('hidden')
      btn.setAttribute('aria-expanded', 'false')
    }

    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden')
      iconOpen.classList.toggle('hidden', !open)
      iconClose.classList.toggle('hidden', open)
      btn.setAttribute('aria-expanded', String(open))
    })

    menu.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu))
  }
</script>
