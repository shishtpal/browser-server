---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Not Found">
  <main class="flex items-center justify-center min-h-[60vh]">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-gray-300 mb-4">404</h1>
      <p class="text-xl text-gray-500 mb-6">Page not found</p>
      <a href="/" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition">Go Home</a>
    </div>
  </main>
</Layout>
