---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Not Found">
  <main class="flex min-h-[calc(100vh-72px)] items-center justify-center px-4 py-10">
    <div class="w-full max-w-xl rounded-[2rem] border border-gray-200/80 bg-white/90 p-8 text-center shadow-2xl shadow-gray-900/10 backdrop-blur-xl transition-colors dark:border-white/10 dark:bg-slate-800/90 dark:shadow-slate-950/20 sm:p-12">
      <div class="mx-auto grid h-20 w-20 place-items-center rounded-[1.75rem] bg-slate-900 text-5xl font-black text-white shadow-xl shadow-slate-900/20 transition-colors dark:bg-slate-950 dark:shadow-slate-950/20">404</div>
      <h1 class="mt-6 text-3xl font-black tracking-tight text-slate-900 transition-colors dark:text-white sm:text-5xl">Page not found</h1>
      <p class="mt-3 text-base leading-7 text-slate-600 transition-colors dark:text-slate-400">The page you are looking for does not exist or has been moved.</p>
      <a href="/" class="mt-6 inline-flex rounded-2xl bg-gradient-to-r from-indigo-600 to-violet-600 px-6 py-3 text-sm font-black text-white shadow-lg shadow-indigo-500/25 transition hover:-translate-y-0.5 hover:shadow-xl hover:shadow-indigo-500/30">
        Go home
      </a>
    </div>
  </main>
</Layout>
